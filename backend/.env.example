# ===============================================
# APLICAÇÃO
# ===============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===============================================
# BANCO DE DADOS (MySQL)
# ===============================================
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=crm_db
MYSQL_USER=crm_user
MYSQL_PASSWORD=crm_pass
DATABASE_URL="mysql://crm_user:crm_pass@localhost:3306/crm_db"

# ===============================================
# REDIS (filas BullMQ)
# ===============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===============================================
# JWT
# ===============================================
JWT_ACCESS_SECRET=troque-este-segredo-para-um-valor-forte-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-tambem-em-producao
JWT_REFRESH_EXPIRES_IN=7d

# ===============================================
# BCRYPT
# ===============================================
BCRYPT_SALT_ROUNDS=12

# ===============================================
# SEED — Gerente inicial
# ===============================================
SEED_MANAGER_NAME="Klaus Toneto"
SEED_MANAGER_EMAIL=admin@crm.local
SEED_MANAGER_PASSWORD=ChangeMe@123
