# ===============================================================
# .env DO BACKEND — LIDO PELO NESTJS E PELO PRISMA
# ===============================================================
# Copie este arquivo:   cp .env.example .env
#
# A DATABASE_URL deve usar as MESMAS credenciais que estão no
# arquivo .env DA RAIZ DO PROJETO (que o Docker usa para o MySQL).
# Se estiverem diferentes, você terá "Access denied".
# ===============================================================

# ===============================================
# APLICAÇÃO
# ===============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ===============================================
# BANCO DE DADOS (MySQL no Docker)
# ===============================================
# Use 127.0.0.1 (evita problemas de IPv6/resolução de localhost
# que ocorrem em Windows + WSL).
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://crm_user:crm_pass@127.0.0.1:3306/crm_db"

# Shadow database — usada APENAS por `prisma migrate dev` em desenvolvimento.
# O Prisma cria e dropa um banco temporário aqui para validar migrations.
# Precisa de um usuário com permissão CREATE DATABASE (usamos root do
# MySQL no Docker). Em PRODUÇÃO, deixe esta linha comentada e use
# `prisma migrate deploy` — esse comando não precisa de shadow.
SHADOW_DATABASE_URL="mysql://root:rootpass@127.0.0.1:3306/crm_shadow_db"

# ===============================================
# REDIS (filas BullMQ)
# ===============================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ===============================================
# JWT — TROQUE EM PRODUÇÃO
# ===============================================
JWT_ACCESS_SECRET=troque-este-segredo-para-um-valor-forte-em-producao
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh-tambem-em-producao
JWT_REFRESH_EXPIRES_IN=7d

# ===============================================
# BCRYPT
# ===============================================
BCRYPT_SALT_ROUNDS=12

# ===============================================
# SEED — Gerente inicial
# ===============================================
SEED_MANAGER_NAME="Klaus Toneto"
SEED_MANAGER_EMAIL=admin@crm.local
SEED_MANAGER_PASSWORD=ChangeMe@123

# ===============================================
# FASE 3 — IA (Anthropic / OpenAI / Google)
# ===============================================
# Configure APENAS as chaves dos providers que você vai usar.
# Cada agente escolhe o seu provider.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Cotação USD/BRL fixa (usada pra mostrar custos em reais).
# Atualize de tempos em tempos.
USD_BRL_RATE=5.20

# ===============================================
# FASE 3 — Evolution API (WhatsApp não-oficial)
# ===============================================
# Se TODAS as 3 variáveis abaixo estiverem preenchidas, o sistema usa
# a Evolution para enviar mensagens. Senão, cai automaticamente no
# MockMessagingService (logs only).

EVOLUTION_URL=http://localhost:8085
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Segredo do webhook — se definido, o endpoint /api/whatsapp/webhook
# só aceita requisições com header `x-webhook-secret: <esse valor>`.
# Configure o mesmo valor na Evolution.
EVOLUTION_WEBHOOK_SECRET=
