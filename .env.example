# ===============================================================
# .env DA RAIZ — LIDO PELO DOCKER COMPOSE
# ===============================================================
# Copie este arquivo:   cp .env.example .env
#
# IMPORTANTE: se trocar qualquer senha DEPOIS de já ter rodado
# `docker compose up`, derrube os volumes para forçar a recriação:
#   docker compose down -v
#   docker compose up -d
# ===============================================================

# --- MySQL principal (backend NestJS) ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=crm_db
MYSQL_USER=crm_user
MYSQL_PASSWORD=crm_pass

# --- Evolution API (WhatsApp não-oficial) ---
# A API_KEY abaixo é usada como AUTHENTICATION_API_KEY na Evolution.
# Use o MESMO valor em backend/.env como EVOLUTION_API_KEY.
EVOLUTION_API_KEY=changeme-evolution-key-aqui

# Senha do Postgres dedicado da Evolution
EVOLUTION_DB_PASSWORD=evolutionpass
