# ============================================
# APLICAÇÃO
# ============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ============================================
# BANCO DE DADOS (MySQL)
# ============================================
# IMPORTANTE: Usar o nome do serviço 'mysql' do docker-compose
# NÃO usar 'localhost' dentro de containers Docker

MYSQL_ROOT_PASSWORD=MYSQL_ROOT_PASSWORD_aqui
MYSQL_DATABASE=crm_db
MYSQL_USER=crm_user
MYSQL_PASSWORD=MYSQL_PASSWORD_aqui

# DATABASE_URL usa o usuário crm_user (não root)
# e o hostname 'mysql' (nome do serviço no docker-compose)
DATABASE_URL="mysql://crm_user:gerar_outra_senha_aleatoria_com_openssl@mysql:3306/crm_db"

# ============================================
# REDIS (filas BullMQ)
# ============================================
# IMPORTANTE: Usar o nome do serviço 'redis' do docker-compose
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# JWT
# ============================================
# Gere valores seguros com: openssl rand -base64 48
JWT_ACCESS_SECRET=JWT_ACCESS_SECRET_aqui
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=JWT_REFRESH_SECRET_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# BCRYPT
# ============================================
BCRYPT_SALT_ROUNDS=12

# ============================================
# SEED — Gerente inicial
# ============================================
SEED_MANAGER_NAME="Klaus Toneto"
SEED_MANAGER_EMAIL=admin@crm.local
SEED_MANAGER_PASSWORD=DefinaUmaSenhaForte2026!

# ============================================
# IA (Anthropic / OpenAI / Google)
# ============================================
# IMPORTANTE: Nunca coloque chaves reais em arquivos de exemplo
# Revogue a chave OpenAI exposta e gere uma nova

ANTHROPIC_API_KEY=
OPENAI_API_KEY=chave_aqui_openai
GEMINI_API_KEY=

# Cotação USD/BRL fixa
USD_BRL_RATE=5.20

# ============================================
# WHATSAPP - WAHA (WhatsApp HTTP API)
# ============================================
# IMPORTANTE: WAHA_URL usa o nome do serviço 'waha' do docker-compose
# NÃO usar 'localhost' dentro de containers Docker

WAHA_URL=http://waha:3000
WAHA_API_KEY=minha-chave-super-segura
WAHA_WEBHOOK_SECRET=secret_para_validar_entrada_de_mensagens

# Credenciais para o Dashboard do WAHA
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=senha_forte_dashboard_waha

# Credenciais para o Swagger do WAHA
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=senha_forte_swagger_waha